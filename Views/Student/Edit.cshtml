

@model StudentPortal.Web.Models.Entities.Student

<h1>Edit Student</h1>
@if (Model == null)
{
   <p>No student was found with this Id</p> 
}else
{
    <form method="post">
        
            <div mt-3>
                <label class="form-label mt-4" >Id</label>
                <input class="form-control" readonly  type="text" asp-for="Id" placeholder="Saisissez votre Name" />
            </div>

            <div>
              <label class="form-label mt-4">Name</label>
              <input class="form-control" type="text" asp-for="Name" placeholder="Saisissez votre Name" />
            </div>

            <div mt-3>
                <label class="form-label mt-4">Email</label>
                <input class="form-control" type="text" asp-for="Email" placeholder="Saisissez votre Email" />
            </div>

            <div mt-3>
                <label class="form-label mt-4">Phone</label>
                <input class="form-control" type="text" asp-for="Phone" placeholder="Saisissez votre Phone" />
            </div>

            <div mt-3>
                <input class="form-check-input mt-4" type="checkbox" asp-for="Subscribed" id="Subscribed" />
                <label class="form-check-label mt-4" for="Subscribed">Subscribed </label>
            </div>

            <div mt-4>
                <button class="btn btn-primary" type="submit">Save</button>

                <button class="btn btn-danger ms-3" type="submit" 
                asp-controller="Student" 
                asp-action="Delete">Delete</button>
            </div>
    
    </form>
}

